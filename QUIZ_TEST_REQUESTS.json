  "9_SUBMIT_QUIZ_WITH_MULTIPLE_CHOICE_AND_CODE": {
    "method": "POST",
    "url": "/api/quizzes/submit/",
    "description": "Submit quiz with both multiple choice and code answers",
    "request_body": {
      "quiz_id": 1,
      "lesson_id": 1,
      "answers": [
        {
          "question_id": 101,
          "selected_option_id": 1
        },
        {
          "question_id": 102,
          "code_answer": "function twoSum(nums, target) {\n  const map = new Map();\n  for (let i = 0; i < nums.length; i++) {\n    const complement = target - nums[i];\n    if (map.has(complement)) {\n      return [map.get(complement), i];\n    }\n    map.set(nums[i], i);\n  }\n}",
          "actual_output": "[0,1]\n[1,2]\n[0,1]"
        }
      ],
      "time_spent": 600
    },
    "expected_response": {
      "quiz_result_id": 301,
      "quiz_id": 1,
      "user_id": 1,
      "score": 100,
      "total_points": 15,
      "earned_points": 15,
      "passing_score": 70,
      "passed": true,
      "time_spent": 600,
