          "text_answer": null,
          "code_answer": "function twoSum(nums, target) {...}",
          "actual_output": "[0,1]\n[1,2]\n[0,1]",
          "is_correct": true,
          "points_earned": 10,
          "correct_answer_explanation": "Use a hash map to store values and their indices for O(n) solution",
          "test_cases_results": [
            {
              "test_case_id": 201,
              "order_number": 1,
              "input": "[2,7,11,15]\n9",
              "expected_output": "[0,1]",
              "actual_output": "[0,1]",
              "passed": true,
              "points": 3
            },
            {
